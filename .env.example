# Copy this file to .env.local and fill in real values.
# Real values are stored in Vercel → Settings → Environment Variables for the deployed app.

# --- Supabase -----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Analytics 4 (optional) --------------------------------------
# Web stream Measurement ID from GA4 Admin → Data streams. Safe as NEXT_PUBLIC_.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Ahrefs Web Analytics (optional) ------------------------------------
# Site key from Ahrefs → Web Analytics → Installation. Safe as NEXT_PUBLIC_.
NEXT_PUBLIC_AHREFS_ANALYTICS_KEY=

# --- Admin API (server-only) --------------------------------------------
# Random secret used to authenticate /api/admin/* endpoints.
# Generate with: openssl rand -hex 32
ADMIN_SECRET=

# --- Site URL -----------------------------------------------------------
# Used by admin API to build absolute claim URLs.
NEXT_PUBLIC_SITE_URL=https://carrentdesk.com

# --- Email (Resend) -----------------------------------------------------
# Get your API key at resend.com → API Keys.
# Requires domain verification (DNS records) before sending from your domain.
RESEND_API_KEY=
# The From address for transactional emails (must match your verified domain).
EMAIL_FROM=CarRentDesk <hello@carrentdesk.com>
# Your email — where access request notifications are delivered.
OWNER_EMAIL=hello@carrentdesk.com
